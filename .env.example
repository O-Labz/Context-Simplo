# Context-Simplo Environment Variables
# Copy this file to .env and customize for your environment

# =============================================================================
# Workspace Configuration
# =============================================================================

# Path on host machine to mount into the container
# For dynamic workspace switching, mount your home directory
HOST_MOUNT_PATH=~

# Legacy workspace path (for backward compatibility with old docker run commands)
WORKSPACE_PATH=.

# Mount root inside the container (where HOST_MOUNT_PATH is mounted)
# Default: /host (for dynamic workspace switching)
MOUNT_ROOT=/host

# Initial workspace directory within the mount to index on startup
# Example: /host/projects/my-app (if HOST_MOUNT_PATH=~ and you want to start in ~/projects/my-app)
# Default: /workspace (for backward compatibility)
INITIAL_WORKSPACE=/workspace

# =============================================================================
# LLM / Embedding Provider Configuration
# =============================================================================

# LLM provider: ollama, openai, or none
# - ollama: Local AI (free, private, requires Ollama running)
# - openai: OpenAI API (requires API key, costs ~$0.02 per 1M tokens)
# - none: Structural tools only (no semantic search)
LLM_PROVIDER=ollama

# API key for OpenAI (only required if LLM_PROVIDER=openai)
LLM_API_KEY=

# Base URL for the LLM provider
# - Ollama (macOS/Windows): http://host.docker.internal:11434
# - Ollama (Linux): http://host.docker.internal:11434 (with extra_hosts in docker-compose.yml)
# - OpenAI: https://api.openai.com/v1
LLM_BASE_URL=http://host.docker.internal:11434

# Embedding model to use
# - Ollama: nomic-embed-text, mxbai-embed-large, all-minilm
# - OpenAI: text-embedding-3-small, text-embedding-3-large
LLM_EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# Context-Simplo Behavior
# =============================================================================

# Data directory inside the container (SQLite + LanceDB storage)
# Default: /data (mounted as a named volume in docker-compose.yml)
CONTEXT_SIMPLO_DATA_DIR=/data

# Auto-index the workspace on startup
# Default: true
CONTEXT_SIMPLO_AUTO_INDEX=true

# Watch for file changes and auto-reindex
# Default: true
CONTEXT_SIMPLO_WATCH=true

# Log level: debug, info, warn, error
# Default: info
CONTEXT_SIMPLO_LOG_LEVEL=info

# Response mode for MCP tools: full or compact
# - full: Complete responses with all metadata
# - compact: ~60% smaller responses (abbreviated keys, no nulls)
# Default: full
CONTEXT_SIMPLO_RESPONSE_MODE=full

# =============================================================================
# Performance Tuning
# =============================================================================

# Embedding queue concurrency (parallel embedding requests)
# Default: 10
EMBEDDING_CONCURRENCY=10

# Embedding batch size (texts per request)
# Default: 50
EMBEDDING_BATCH_SIZE=50

# Graph memory limit in MB (in-memory graph size before spilling to disk)
# Default: 512
GRAPH_MEMORY_LIMIT_MB=512

# Node.js max old space size (heap memory limit)
# Default: 8192 (8GB)
NODE_OPTIONS=--max-old-space-size=8192
